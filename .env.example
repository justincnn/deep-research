# 这是一个 .env 文件的示例。
# 将此文件复制到 .env 并为您的环境填写值。

# (可选) 服务器 API 访问密码，用于增强安全性
ACCESS_PASSWORD=

# ===================================================================
# AI 提供商设置
# ===================================================================

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com

# --- Google Gemini ---
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_API_BASE_URL=https://generativelanguage.googleapis.com

# --- Google Vertex AI ---
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_PRIVATE_KEY_ID=

# --- Anthropic ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# --- DeepSeek ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# --- XAI ---
# XAI_API_KEY=
# XAI_API_BASE_URL=https://api.x.ai

# --- Mistral ---
# MISTRAL_API_KEY=
# MISTRAL_API_BASE_URL=https://api.mistral.ai

# --- Azure OpenAI ---
# AZURE_API_KEY=
# AZURE_API_VERSION=
# AZURE_RESOURCE_NAME=

# --- OpenAI 兼容 (例如 One API, New API 等服务) ---
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_API_BASE_URL=

# --- Pollinations.ai ---
# POLLINATIONS_API_BASE_URL=https://text.pollinations.ai/openai

# --- Ollama ---
# OLLAMA_API_BASE_URL=http://localhost:11434

# ===================================================================
# 搜索提供商设置
# ===================================================================

# --- Tavily ---
# TAVILY_API_KEY=
# TAVILY_API_BASE_URL=https://api.tavily.com
# (可选) 搜索类别。'news' 用于检索实时更新，特别是关于政治、体育和主流媒体报道的重大时事。'general' 用于更广泛、通用的搜索，可能包括各种来源。
# 可用选项: general, news
# TAVILY_TOPIC=general
# (可选) 搜索深度。'advanced' 搜索旨在检索与您的查询最相关的来源和内容片段，而 'basic' 搜索则提供每个来源的通用内容片段。基础搜索消耗1个API信用点，高级搜索消耗2个API信用点。
# 可用选项: basic, advanced
# TAVILY_SEARCH_DEPTH=basic
# (可选) 每个来源返回的最大相关内容块数。内容块是直接从来源中提取的短内容片段（每个最多500个字符）。仅在 search_depth 为 advanced 时可用。
# 要求范围: 1 <= x <= 3
# TAVILY_CHUNKS_PER_SOURCE=3
# (可选) 返回的最大搜索结果数。
# 要求范围: 0 <= x <= 20
# TAVILY_MAX_RESULTS=5
# (可选) 从当前日期开始的时间范围，用于筛选结果（按发布日期）。当寻找在特定时间范围内发布的数据源时很有用。
# 可用选项: day, week, month, year, d, w, m, y
# TAVILY_TIME_RANGE=
# (可选) 从当前日期算起的天数，用于包含结果（按发布日期）。仅在 topic 为 news 时可用。
# 要求范围: x >= 1
# TAVILY_DAYS=7
# (可选) 将返回指定开始日期之后的所有结果（按发布日期）。要求格式为 YYYY-MM-DD。
# TAVILY_START_DATE=
# (可选) 将返回指定结束日期之前的所有结果（按发布日期）。要求格式为 YYYY-MM-DD。
# TAVILY_END_DATE=

# --- Firecrawl ---
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev

# --- Exa ---
# EXA_API_KEY=
# EXA_API_BASE_URL=https://api.exa.ai

# --- Bocha ---
# BOCHA_API_KEY=
# BOCHA_API_BASE_URL=https://api.bochaai.com

# --- SearxNG ---
# SEARXNG_API_BASE_URL=http://localhost:8080

# ===================================================================
# MCP (多智能体并行) 服务器设置
# ===================================================================

# (可选) MCP 服务器 AI 提供商
# 可能的值: google, openai, anthropic, deepseek, xai, mistral, azure, openrouter, openaicompatible, pollinations, ollama
MCP_AI_PROVIDER=openai

# (可选) MCP 服务器搜索提供商。默认为 `model`
# 可能的值: model, tavily, firecrawl, exa, bocha, searxng
MCP_SEARCH_PROVIDER=model

# (可选) MCP 服务器思考模型ID，深度研究中使用的核心模型。
MCP_THINKING_MODEL=gpt-4

# (可选) MCP 服务器任务模型ID，用于次要任务，建议使用高输出效率的模型。
MCP_TASK_MODEL=gpt-3.5-turbo

# ===================================================================
# 其他设置
# ===================================================================

# (可选) 禁用服务器端 AI 提供商的使用权限
# NEXT_PUBLIC_DISABLED_AI_PROVIDER=

# (可选) 禁用服务器端搜索提供商的使用权限
# NEXT_PUBLIC_DISABLED_SEARCH_PROVIDER=

# (可选) 自定义模型列表，添加或删除模型
# NEXT_PUBLIC_MODEL_LIST=

# (可选) 注入的脚本代码，可用于统计或错误跟踪。
# HEAD_SCRIPTS=
