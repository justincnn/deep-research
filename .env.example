# This is an example .env file. 
# Copy this file to .env and fill in the values for your environment.

# (Optional) Server API Access Password for enhanced security
ACCESS_PASSWORD=

# ===================================================================
# AI Provider Settings
# ===================================================================

# --- OpenAI --- 
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com

# --- Google Gemini ---
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_API_BASE_URL=https://generativelanguage.googleapis.com

# --- Google Vertex AI ---
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_PRIVATE_KEY_ID=

# --- Anthropic ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# --- DeepSeek ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# --- XAI ---
# XAI_API_KEY=
# XAI_API_BASE_URL=https://api.x.ai

# --- Mistral ---
# MISTRAL_API_KEY=
# MISTRAL_API_BASE_URL=https://api.mistral.ai

# --- Azure OpenAI ---
# AZURE_API_KEY=
# AZURE_API_VERSION=
# AZURE_RESOURCE_NAME=

# --- OpenAI Compatible (for services like One API, New API) ---
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_API_BASE_URL=

# --- Pollinations.ai ---
# POLLINATIONS_API_BASE_URL=https://text.pollinations.ai/openai

# --- Ollama ---
# OLLAMA_API_BASE_URL=http://localhost:11434

# ===================================================================
# Search Provider Settings
# ===================================================================

# --- Tavily ---
# TAVILY_API_KEY=
# TAVILY_API_BASE_URL=https://api.tavily.com

# --- Firecrawl ---
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev

# --- Exa ---
# EXA_API_KEY=
# EXA_API_BASE_URL=https://api.exa.ai

# --- Bocha ---
# BOCHA_API_KEY=
# BOCHA_API_BASE_URL=https://api.bochaai.com

# --- SearxNG ---
# SEARXNG_API_BASE_URL=http://localhost:8080

# ===================================================================
# MCP (Multi-Copilot Parallel) Server Settings
# ===================================================================

# (Optional) MCP Server AI provider
# Possible values: google, openai, anthropic, deepseek, xai, mistral, azure, openrouter, openaicompatible, pollinations, ollama
MCP_AI_PROVIDER=openai

# (Optional) MCP Server search provider. Default, `model`
# Possible values: model, tavily, firecrawl, exa, bocha, searxng
MCP_SEARCH_PROVIDER=model

# (Optional) MCP Server thinking model id, the core model used in deep research.
MCP_THINKING_MODEL=gpt-4

# (Optional) MCP Server task model id, used for secondary tasks, high output models are recommended.
MCP_TASK_MODEL=gpt-3.5-turbo

# ===================================================================
# Other Settings
# ===================================================================

# (Optional) Disable server-side AI provider usage permissions
# NEXT_PUBLIC_DISABLED_AI_PROVIDER=

# (Optional) Disable server-side search provider usage permissions
# NEXT_PUBLIC_DISABLED_SEARCH_PROVIDER=

# (Optional) Customize the model list, add or delete models
# NEXT_PUBLIC_MODEL_LIST=

# (Optional) Injected script code can be used for statistics or error tracking.
# HEAD_SCRIPTS=
